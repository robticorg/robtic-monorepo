{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "utiles/*": ["./src/utiles/*"],
      "lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["dist"],
  "references": [
    { "path": "../../libs/shared" },
    { "path": "../../libs/config" },
    { "path": "../../libs/database" },
    { "path": "../../libs/logger" }
  ]
}
