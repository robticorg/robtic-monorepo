{
  "name": "@robo/db",
  "type": "module",
  "module": "dist/db.js",
  "main": "dist/db.js",
  "types": "dist/db.d.ts",
  "scripts": {
    "build": "bun run generate && bun run build:js && bun run build:types",
    "build:js": "bun build ./src/db.ts --outdir ./dist --target bun --format esm --external @robo/logger --external @robo/shared",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "bun run build:js --watch",
    "generate": "bunx prisma generate --schema=./prisma/schema.prisma",
    "migrate": "bunx prisma migrate dev --name init --schema=./prisma/schema.prisma",
    "studio": "bunx prisma studio --schema=./prisma/schema.prisma",
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@robo/logger": "workspace:*",
    "@robo/shared": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "pg": "^8.16.3",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0"
  },
  "exports": {
    ".": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js",
      "default": "./dist/db.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js",
      "default": "./dist/db.js"
    }
  }
}
