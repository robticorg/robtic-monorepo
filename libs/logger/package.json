{
  "name": "@robo/logger",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external @robo/shared",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "bun run src/examples/use-logger.ts",
    "watch": "bun run build:js --watch",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@robo/shared": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.9",
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.1",
    "@types/node": "^20.3.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
