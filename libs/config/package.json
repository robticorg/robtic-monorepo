{
    "name": "@robo/config",
    "type": "module",
    "scripts": {
        "build": "bun run build:js && bun run build:types",
        "build:js": "bun build ./src/env.ts ./src/database.ts --outdir ./dist --target bun --format esm --external @robo/logger",
        "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
        "dev": "bun run build:js --watch"
    },
    "dependencies": {
        "@robo/logger": "workspace:*",
        "dotenv": "^17.2.3",
        "mongoose": "^8.19.1"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.5.0"
    },
    "module": "dist/env.js",
    "main": "dist/env.js",
    "exports": {
        ".": {
            "types": "./dist/env.d.ts",
            "import": "./dist/env.js",
            "default": "./dist/env.js"
        },
        "./env": {
            "types": "./dist/env.d.ts",
            "import": "./dist/env.js",
            "default": "./dist/env.js"
        },
        "./database": {
            "types": "./dist/database.d.ts",
            "import": "./dist/database.js",
            "default": "./dist/database.js"
        }
    }
}
